# Optional: override marketing inquiry POST URL (default: Oracle public HTTPS)
# VITE_MARKETING_INQUIRY_PROXY_URL=https://webhook.aideazz.xyz/cto/marketing/inquiry-proxy
#
# SPA redirect: /cto/* (e.g. /cto/leads/dashboard?secret=…) → CTO AIPA on webhook host
# VITE_CTO_WEBHOOK_ORIGIN=https://webhook.aideazz.xyz
#
# Google reCAPTCHA v3 site key (public) — must match RECAPTCHA_SECRET_KEY on CTO AIPA
# reCAPTCHA Enterprise (GCP) — must match CTO AIPA RECAPTCHA_SITE_KEY + secret
# VITE_RECAPTCHA_SITE_KEY=
