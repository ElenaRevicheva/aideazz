# Static files under /ops/* are served from public/ops (income ops dashboard). SPA fallback below must not mask them — most hosts resolve real files first.

/.gitignore    /    301
/card          /portfolio    301
# Per-article static blog HTML pages (SEO/GEO discoverability — generated by cto-aipa blog-static-pages.ts).
# Must come BEFORE the SPA catch-all so /blog/{slug} (no trailing slash) serves the real article HTML.
/blog/:slug    /blog/:slug/index.html    200
# GSC URL-prefix property needs /portfolio/sitemap.* — rewrite to FLAT files.
# NEVER use public/portfolio/ directory (IPFS serves DirIndex and kills /portfolio/).
/portfolio/sitemap.xml    /portfolio-sitemap.xml    200
/portfolio/sitemap.txt     /portfolio-sitemap.txt     200
# Prerendered money pages — flat .html so /portfolio is not an IPFS directory (no 301).
/portfolio      /portfolio.html         200
/portfolio/     /portfolio.html         200
/api            /api.html               200
/api/           /api.html               200
/*             /index.html   200
